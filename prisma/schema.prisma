generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  BUYER
  SUPPLIER
  ADMIN
  INSPECTOR
}

model User {
  id                 String       @id @default(uuid())
  email              String       @unique
  passwordHash       String       @map("password_hash")
  role               Role         @default(BUYER)
  mustChangePassword Boolean      @default(false) @map("must_change_password")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  sessions           Session[]
  auditEvents        AuditEvent[]
  supplier           Supplier?
  suppliersReviewed  Supplier[]   @relation("KycReviewer")
  rfqsAsBuyer        RFQ[]        @relation("RfqBuyer")
  transitionsActedBy Transition[] @relation("TransitionActor")

  @@map("users")
}

model Session {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

enum AuditEventType {
  LOGIN
  LOGOUT
  REGISTER
  LOGIN_FROM_NEW_DEVICE
  PASSWORD_CHANGED
  USER_INVITED
  KYC_APPROVED
  KYC_REJECTED
  LISTING_HIDDEN
  LISTING_RESTORED
}

model AuditEvent {
  id          String         @id @default(uuid())
  type        AuditEventType
  actorUserId String?        @map("actor_user_id")
  actor       User?          @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  sessionId   String?        @map("session_id")
  ipAddress   String?        @map("ip_address")
  userAgent   String?        @map("user_agent")
  payload     Json?
  createdAt   DateTime       @default(now()) @map("created_at")

  @@index([actorUserId])
  @@index([type])
  @@index([createdAt])
  @@map("audit_events")
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  REJECTED
}

enum LeadRoleIntent {
  BUYER
  SUPPLIER
}

model Lead {
  id         String          @id @default(uuid())
  email      String
  name       String?
  message    String
  roleIntent LeadRoleIntent? @map("role_intent")
  status     LeadStatus      @default(NEW)
  ipAddress  String?         @map("ip_address")
  userAgent  String?         @map("user_agent")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt])
  @@map("leads")
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

model Supplier {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName     String    @map("company_name")
  country         String
  phone           String?
  kycStatus       KycStatus @default(PENDING) @map("kyc_status")
  kycReason       String?   @map("kyc_reason")
  kycReviewedAt   DateTime? @map("kyc_reviewed_at")
  kycReviewedById String?   @map("kyc_reviewed_by_id")
  kycReviewedBy   User?     @relation("KycReviewer", fields: [kycReviewedById], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  listings        Listing[]
  quotes          Quote[]

  @@index([kycStatus])
  @@map("suppliers")
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

model Listing {
  id                   String        @id @default(uuid())
  supplierId           String        @map("supplier_id")
  supplier             Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  title                String
  description          String
  material             String?
  origin               String?
  size                 String?
  dimensions           String?
  weave                String?
  indicativePriceCents Int?          @map("indicative_price_cents")
  tags                 String[]
  status               ListingStatus @default(DRAFT)
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  photos               Photo[]
  rfqs                 RFQ[]

  @@index([status])
  @@index([supplierId])
  @@index([createdAt])
  @@map("listings")
}

model Photo {
  id           String   @id @default(uuid())
  listingId    String   @map("listing_id")
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  objectKey    String   @unique @map("object_key")
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([listingId])
  @@map("listing_photos")
}

enum RfqStatus {
  DRAFT
  SUBMITTED
  QUOTED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum QuoteStatus {
  ACTIVE
  ACCEPTED
  REJECTED
}

model RFQ {
  id          String       @id @default(uuid())
  buyerId     String       @map("buyer_id")
  buyer       User         @relation("RfqBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  listingId   String       @map("listing_id")
  listing     Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  message     String
  quantity    Int?
  status      RfqStatus    @default(DRAFT)
  expiresAt   DateTime?    @map("expires_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  quotes      Quote[]
  transitions Transition[]

  @@index([buyerId])
  @@index([listingId])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("rfqs")
}

model Quote {
  id         String      @id @default(uuid())
  rfqId      String      @map("rfq_id")
  rfq        RFQ         @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  supplierId String      @map("supplier_id")
  supplier   Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  priceCents Int         @map("price_cents")
  quantity   Int
  message    String
  status     QuoteStatus @default(ACTIVE)
  validUntil DateTime?   @map("valid_until")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@index([rfqId])
  @@index([supplierId])
  @@index([status])
  @@map("quotes")
}

model Transition {
  id         String    @id @default(uuid())
  rfqId      String    @map("rfq_id")
  rfq        RFQ       @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  actorId    String    @map("actor_id")
  actor      User      @relation("TransitionActor", fields: [actorId], references: [id], onDelete: Cascade)
  fromStatus RfqStatus @map("from_status")
  toStatus   RfqStatus @map("to_status")
  reason     String?
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([rfqId])
  @@index([createdAt])
  @@map("transitions")
}
